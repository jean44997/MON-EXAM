{
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    {
      "src": "/_expo/static/(.*)",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "dest": "/_expo/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1",
      "check": true
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
